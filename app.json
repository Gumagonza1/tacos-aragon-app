{
  "expo": {
    "name": "Tacos Aragón",
    "slug": "tacos-aragon-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tacosaragon.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.tacosaragon.app",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-av",
        { "microphonePermission": "Tacos Aragón necesita el micrófono para comandos de voz" }
      ],
      "./plugins/withNetworkSecurity"
    ],
    "extra": {
      "eas": { "projectId": "a1606d7d-7c0c-4a79-b27a-ea620b87c338" }
    },
    "owner": "gaga4812"
  }
}
